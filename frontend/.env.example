# Frontend environment variables.
# Copy to .env and customize for your local setup.

# Backend API base URL. Set to /api/v1 for Vite proxy, or full URL for direct access.
VITE_API_BASE_URL=/api/v1

# Backend origin for static uploads (tool photos).
VITE_API_TARGET=http://localhost:8000

# Set to 'true' to bypass backend and use mock data fixtures.
VITE_USE_MOCKS=false
