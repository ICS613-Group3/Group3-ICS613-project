# Frontend environment for the R1 demo.
#
# Copy this to .env and edit as needed. The .env file is gitignored.
#
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# Don't put secrets here — anything in this file ends up in the JS.

# Backend API base URL. The default "/api/v1" relies on the Vite dev
# proxy (configured in vite.config.ts) which forwards /api/* to
# http://localhost:8000. If you deploy the frontend separately and want
# to hit the backend directly, set this to the full origin, e.g.
#   VITE_API_BASE_URL=http://localhost:8000/api/v1
#   VITE_API_BASE_URL=https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Optional: a pre-issued invite token to pre-fill the registration form.
# Leave blank to require the user to paste their own token. The seed
# script creates an invite for newmember@example.com — its token is
# printed in the server log on seed and also returned in the
# POST /admin/invites response.
VITE_DEV_INVITE_TOKEN=
